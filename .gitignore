# Ignore everything
*

# Allow gitignore itself and shell files
!.gitignore
!.zshrc
!.p10k.zsh

# Unignore the .config directory
!.config/

# Unignore files in the .config directory
!.config/rofimoji.rc

## Unignore specific folders
!.config/hypr/
!.config/kitty/
!.config/nvim/
!.config/rofi/
!.config/swaync/
!.config/waybar/

### Unignore files inside those folders
!.config/hypr/*
!.config/kitty/*
!.config/nvim/*
!.config/rofi/*
!.config/swaync/*
!.config/waybar/*
